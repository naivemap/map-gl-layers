  "types": "./dist/index.d.ts",
  "repository": "https://github.com/naivemap/maplibre-gl-layers",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "typedocs": "typedoc"
  }
