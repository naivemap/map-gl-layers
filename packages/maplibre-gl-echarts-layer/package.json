{
  "name": "@naivemap/maplibre-gl-echarts-layer",
  "version": "0.2.0-alpha.2",
  "description": "A MapLibre GL JS layer to integrate Apache ECharts' Lines and Scatter charts.",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "maplibre",
    "echarts",
    "layer",
    "custom"
  ],
  "author": "naivemap",
  "license": "MIT",
  "types": "./dist/index.d.ts",
  "repository": "https://github.com/naivemap/maplibre-gl-layers",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "typedocs": "pnpm typedoc"
  },
  "dependencies": {
    "@naivemap/echarts-layer-core": "workspace:*",
    "@naivemap/map-gl-layer-adaptor": "workspace:*"
  },
  "peerDependencies": {
    "echarts": "^5.0.0",
    "maplibre-gl": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "echarts": "^5.6.0",
    "maplibre-gl": "^5.6.1"
  }
}
