{
  "name": "@naivemap/maplibre-gl-image-layer",
  "version": "0.2.0-alpha.0",
  "description": "Load a static image of any projection via Arrugator and Proj4js.",
  "main": "./dist/index.umd.js",
  "module": "./dist/index.es.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "maplibre",
    "image",
    "layer",
    "custom"
  ],
  "author": "naivemap",
  "license": "MIT",
  "types": "./dist/index.d.ts",
  "repository": "https://github.com/naivemap/maplibre-gl-layers",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "typedocs": "pnpm typedoc"
  },
  "peerDependencies": {
    "maplibre-gl": "^4.0.0 || ^5.0.0",
    "proj4": "^2.8.0"
  },
  "dependencies": {
    "@naivemap/map-gl-layer-adaptor": "workspace:*",
    "@naivemap/image-layer-core": "workspace:*"
  },
  "devDependencies": {
    "@types/proj4": "^2.5.2"
  }
}
