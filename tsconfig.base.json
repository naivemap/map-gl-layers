{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@naivemap/gl-layer-adaptor": ["packages/gl-layer-adaptor/src/index.ts"],
      "@naivemap/echarts-layer-core": ["packages/echarts-layer-core/src/index.ts"],
      "@naivemap/image-layer-core": ["packages/image-layer-core/src/index.ts"]
    },
    "moduleResolution": "bundler",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["es2024", "DOM"],
    "skipLibCheck": true,
    /* Bundler mode */
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true
  }
}
